# Supabase 项目地址，来自 Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase publishable key，可以放在前端，但当前阶段暂时不会使用
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# Prisma 连接数据库用。
# 注意：真正的 DATABASE_URL 里面有数据库密码，只能放到本地 .env，不能提交到 Git。
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma 做数据库迁移时用的直连地址。
# 注意：真正的 DIRECT_URL 也包含数据库密码，只能放到本地 .env，不能提交到 Git。
DIRECT_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"
